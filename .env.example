# Google Apps Script Web App URL (backend REST API)
GAS_WEBAPP_URL=https://script.google.com/macros/s/your-deployment-id/exec

# LLM API Keys (optional - app works without them via regex parser)
# Get free key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Get free key from: https://console.groq.com/keys
GROQ_API_KEY=

# Development
# Set to 'true' to force offline mode (localStorage only, no GAS calls)
FORCE_OFFLINE_MODE=false
